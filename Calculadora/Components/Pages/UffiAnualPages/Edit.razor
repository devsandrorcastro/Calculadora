@page "/uffianuals/edit"
@using Microsoft.EntityFrameworkCore
@using CalculadoraDebitos.Models
@inject IDbContextFactory<CalculadoraDebitos.Data.AppDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit</PageTitle>

<h1>Editar</h1>

<h2>Uffi Anual</h2>
<hr />
@if (UffiAnual is null)
{
    <p><em>Carregando...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="UffiAnual" OnValidSubmit="UpdateUffiAnual" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert"/>
                <input type="hidden" name="UffiAnual.Id" value="@UffiAnual.Id" />
                <div class="mb-3">
                    <label for="ano" class="form-label">Ano:</label>
                    <InputNumber id="ano" @bind-Value="UffiAnual.Ano" class="form-control" />
                    <ValidationMessage For="() => UffiAnual.Ano" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="valor" class="form-label">Valor:</label>
                    <InputNumber id="valor" @bind-Value="UffiAnual.Valor" class="form-control" />
                    <ValidationMessage For="() => UffiAnual.Valor "  class="text-danger" />
                </div>
                <button type="submit" class="btn btn-primary">Salvar</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/uffianuals">Voltar a Listagem</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private int Id { get; set; }

    [SupplyParameterFromForm]
    private UffiAnual? UffiAnual { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        UffiAnual ??= await context.UffiAnual.FirstOrDefaultAsync(m => m.Id == Id);
        UffiAnual.Valor = UffiAnual.Valor / 100;
        if (UffiAnual is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    // To protect from overposting attacks, enable the specific properties you want to bind to.
    // For more information, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task UpdateUffiAnual()
    {
        using var context = DbFactory.CreateDbContext();
        UffiAnual.Valor = UffiAnual.Valor * 100;
        context.Attach(UffiAnual!).State = EntityState.Modified;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!UffiAnualExists(UffiAnual!.Id))
            {
                NavigationManager.NavigateTo("notfound");
            }
            else
            {
                throw;
            }
        }

        NavigationManager.NavigateTo("/uffianuals");
    }

    private bool UffiAnualExists(int id)
    {
        using var context = DbFactory.CreateDbContext();
        return context.UffiAnual.Any(e => e.Id == id);
    }
}
